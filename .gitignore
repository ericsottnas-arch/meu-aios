
# ============================================
# SYNKRA AIOS - Repo de Contexto Compartilhado
# Apenas: docs/ memory/ .claude/commands/
# ============================================

# IGNORAR TUDO por padrão
*

# PERMITIR apenas pastas de contexto
!.gitignore
!scripts/
!scripts/**
!docs/
!docs/**
!memory/
!memory/**
!.claude/
!.claude/commands/
!.claude/commands/**
!.claude/CLAUDE.md
!.aios-core/
!.aios-core/development/
!.aios-core/development/agents/
!.aios-core/development/agents/**

# Dentro de docs, permitir tudo EXCETO binários pesados
docs/**/*.db
docs/**/*.db-shm
docs/**/*.db-wal

# Dentro de meu-projeto, permitir só docs
!meu-projeto/
!meu-projeto/docs/
!meu-projeto/docs/**
!meu-projeto/data/
!meu-projeto/data/knowledge-base/
!meu-projeto/data/knowledge-base/**
!meu-projeto/design-feedback-rules.json
!meu-projeto/assets/
!meu-projeto/assets/brands/
!meu-projeto/assets/brands/**

# Sempre ignorar
.DS_Store
*.log
.env
.env.*
*.key
*.pem
*.db
*.db-shm
*.db-wal
node_modules/
.claude/projects/
.claude/settings.local.json
