    {"id":"t-s3-label","type":"text","x":62,"y":538,"width":876,"height":13,"angle":0,"strokeColor":"#888888","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":81,"version":1,"versionNonce":81,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"ETAPA 3  ·  MOMENTO ATUAL","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":9,"containerId":null,"originalText":"ETAPA 3  ·  MOMENTO ATUAL"},
    {"id":"t-s3-content","type":"text","x":62,"y":554,"width":876,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":82,"version":1,"versionNonce":82,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"\"Como você se descreve hoje?\"\n\n• Crescendo, mas em ritmo muito abaixo do que sei que é possível\n• Estagnado — o negócio funciona mas não evolui\n• Num momento de virada — preciso de decisão e de um ambiente novo\n• Já opero bem — quero subir o nível de pessoas e oportunidades ⭐ (lead mais qualificado)","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"\"Como você se descreve hoje?\"\n\n• Crescendo, mas em ritmo muito abaixo do que sei que é possível\n• Estagnado — o negócio funciona mas não evolui\n• Num momento de virada — preciso de decisão e de um ambiente novo\n• Já opero bem — quero subir o nível de pessoas e oportunidades ⭐ (lead mais qualificado)"},

