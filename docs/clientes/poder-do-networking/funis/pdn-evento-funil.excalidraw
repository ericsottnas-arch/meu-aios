    {"id":"r-s1","type":"rectangle","x":50,"y":210,"width":900,"height":145,"angle":0,"strokeColor":"#3d3d3d","backgroundColor":"#1c1c1c","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":40,"version":1,"versionNonce":40,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false},
    {"id":"t-s1-label","type":"text","x":62,"y":218,"width":876,"height":13,"angle":0,"strokeColor":"#888888","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":41,"version":1,"versionNonce":41,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"ETAPA 1  ·  PAIN POINT — O QUE TRAVA","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":9,"containerId":null,"originalText":"ETAPA 1  ·  PAIN POINT — O QUE TRAVA"},
    {"id":"t-s1-content","type":"text","x":62,"y":234,"width":876,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":42,"version":1,"versionNonce":42,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"\"O que mais trava o crescimento do seu negócio hoje?\"\n\n• Tudo depende de mim — tenho teto de faturamento e não consigo escalar\n• Falta clareza e foco — começo muita coisa mas não executo o que importa\n• Meu ambiente não me puxa pra cima — rodeado das mesmas pessoas\n• Tenho o negócio, mas falta mentalidade para operar no próximo nível","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"\"O que mais trava o crescimento do seu negócio hoje?\"\n\n• Tudo depende de mim — tenho teto de faturamento e não consigo escalar\n• Falta clareza e foco — começo muita coisa mas não executo o que importa\n• Meu ambiente não me puxa pra cima — rodeado das mesmas pessoas\n• Tenho o negócio, mas falta mentalidade para operar no próximo nível"},

    {"id":"a-23","type":"arrow","x":500,"y":355,"width":1,"height":15,"angle":0,"strokeColor":"#555555","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":2},"seed":50,"version":1,"versionNonce":50,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"points":[[0,0],[0,15]],"lastCommittedPoint":null,"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":"arrow"},

    {"id":"r-s2","type":"rectangle","x":50,"y":370,"width":900,"height":145,"angle":0,"strokeColor":"#3d3d3d","backgroundColor":"#1c1c1c","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":60,"version":1,"versionNonce":60,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false},
    {"id":"t-s2-label","type":"text","x":62,"y":378,"width":876,"height":13,"angle":0,"strokeColor":"#888888","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":61,"version":1,"versionNonce":61,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"ETAPA 2  ·  TRANSFORMAÇÃO DESEJADA","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":9,"containerId":null,"originalText":"ETAPA 2  ·  TRANSFORMAÇÃO DESEJADA"},
    {"id":"t-s2-content","type":"text","x":62,"y":394,"width":876,"height":112,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":62,"version":1,"versionNonce":62,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"\"Se daqui a 6 meses você olhar pra trás e disser 'foi aí que mudou', o que terá acontecido?\"\n\n• Meu faturamento terá crescido com um processo que não depende só de mim\n• Vou estar rodeado de pessoas que me puxam pra cima, não mais das mesmas\n• Vou ter clareza e foco pra executar o que realmente importa\n• Vou operar com a mentalidade e gestão emocional de quem está no alto nível","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"\"Se daqui a 6 meses você olhar pra trás e disser 'foi aí que mudou', o que terá acontecido?\"\n\n• Meu faturamento terá crescido com um processo que não depende só de mim\n• Vou estar rodeado de pessoas que me puxam pra cima, não mais das mesmas\n• Vou ter clareza e foco pra executar o que realmente importa\n• Vou operar com a mentalidade e gestão emocional de quem está no alto nível"},

