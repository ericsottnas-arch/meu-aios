    {"id":"r-s5","type":"rectangle","x":50,"y":950,"width":900,"height":170,"angle":0,"strokeColor":"#d4a017","backgroundColor":"#1e1500","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":140,"version":1,"versionNonce":140,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false},
    {"id":"t-s5-label","type":"text","x":62,"y":958,"width":876,"height":13,"angle":0,"strokeColor":"#d4a017","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":141,"version":1,"versionNonce":141,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"ETAPA 5  ·  ⭐ INTENÇÃO DE COMPRA  —  PERGUNTA MAIS ESTRATÉGICA DO FUNIL","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":9,"containerId":null,"originalText":"ETAPA 5  ·  ⭐ INTENÇÃO DE COMPRA  —  PERGUNTA MAIS ESTRATÉGICA DO FUNIL"},
    {"id":"t-s5-content","type":"text","x":62,"y":974,"width":876,"height":136,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":142,"version":1,"versionNonce":142,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"\"Para um dia de imersão que pode mudar o nível do seu negócio e das suas conexões, como você decide?\"\n\n🔥  \"Vou na experiência completa\"         →  Lead QUENTE   —  SDR contata em até 2h + link de compra\n🟡  \"Avalio o custo-benefício\"              →  Lead MORNO    —  Sequência prova social + ROI do evento\n🔵  \"Prefiro o ingresso de entrada\"       →  Lead FRIO        —  Oferta ingresso básico\n⚠️   \"Depende do momento financeiro\"  →  FINANCEIRO    —  Parcelamento + urgência + escassez","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"\"Para um dia de imersão que pode mudar o nível do seu negócio e das suas conexões, como você decide?\"\n\n🔥  \"Vou na experiência completa\"         →  Lead QUENTE   —  SDR contata em até 2h + link de compra\n🟡  \"Avalio o custo-benefício\"              →  Lead MORNO    —  Sequência prova social + ROI do evento\n🔵  \"Prefiro o ingresso de entrada\"       →  Lead FRIO        —  Oferta ingresso básico\n⚠️   \"Depende do momento financeiro\"  →  FINANCEIRO    —  Parcelamento + urgência + escassez"},

