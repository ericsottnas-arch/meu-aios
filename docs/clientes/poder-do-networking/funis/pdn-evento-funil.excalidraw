    {"id":"t-s4a-label","type":"text","x":62,"y":698,"width":876,"height":13,"angle":0,"strokeColor":"#888888","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":101,"version":1,"versionNonce":101,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"ETAPA 4a  ·  SEGMENTAÇÃO GEOGRÁFICA","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":9,"containerId":null,"originalText":"ETAPA 4a  ·  SEGMENTAÇÃO GEOGRÁFICA"},
    {"id":"t-s4a-content","type":"text","x":62,"y":714,"width":876,"height":82,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":102,"version":1,"versionNonce":102,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"\"Você está no Brasil ou fora?\"\n\n• No Brasil  →  segue para Etapa 4b\n• Nos EUA ou vou estar nos EUA     • Na Europa     • Outro país","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"\"Você está no Brasil ou fora?\"\n\n• No Brasil  →  segue para Etapa 4b\n• Nos EUA ou vou estar nos EUA     • Na Europa     • Outro país"},

