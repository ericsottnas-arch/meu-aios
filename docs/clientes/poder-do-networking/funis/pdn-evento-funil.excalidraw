    {"id":"t-s4b-label","type":"text","x":62,"y":828,"width":876,"height":13,"angle":0,"strokeColor":"#888888","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":121,"version":1,"versionNonce":121,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"ETAPA 4b  ·  CIDADE (apenas Brasil)","fontSize":11,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":9,"containerId":null,"originalText":"ETAPA 4b  ·  CIDADE (apenas Brasil)"},
    {"id":"t-s4b-content","type":"text","x":62,"y":844,"width":876,"height":82,"angle":0,"strokeColor":"#cccccc","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":122,"version":1,"versionNonce":122,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"\"Qual cidade fica mais viável para você?\"\n\n• São Paulo ou região     • Rio de Janeiro ou região\n• Belo Horizonte, Brasília ou Goiânia     • Outra cidade","fontSize":13,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"\"Qual cidade fica mais viável para você?\"\n\n• São Paulo ou região     • Rio de Janeiro ou região\n• Belo Horizonte, Brasília ou Goiânia     • Outra cidade"},

